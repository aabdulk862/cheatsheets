---
import CheatsheetLayout from '../layouts/CheatsheetLayout.astro';
import PatternCard from '../components/PatternCard.astro';
import QuestionCard from '../components/QuestionCard.astro';
import GamePlanPanel from '../components/GamePlanPanel.astro';
import MappingPanel from '../components/MappingPanel.astro';
import SystemDesignPanel from '../components/SystemDesignPanel.astro';
import IntroPanel from '../components/IntroPanel.astro';
import StoryRouter from '../components/StoryRouter.astro';
import { allstateConfig, allstateTddPatterns, allstateJavaPatterns, allstateQuestions, allstateGamePlan } from '../data/allstate';
import { allstateExperience } from '../data/experience-allstate';
import { allstateExtras } from '../data/interview-extras';
---

<CheatsheetLayout
  title={allstateConfig.title}
  subtitle="Recruiter Screen → Technical Coding → Pair Programming/TDD Round"
  accentColor={allstateConfig.accentColor}
  accentSecondary={allstateConfig.accentSecondary}
  tabs={allstateConfig.tabs}
  timerMinutes={allstateConfig.timerMinutes}
  hasSearch={true}
>
  <div id="panel-tdd" class="panel active" role="tabpanel" aria-labelledby="tab-tdd">
    {allstateTddPatterns.map(section => (
      <Fragment>
        <div class="section-label">{section.label}</div>
        <div class="pattern-grid">
          {section.cards.map(card => <PatternCard {...card} />)}
        </div>
      </Fragment>
    ))}
  </div>

  <div id="panel-java" class="panel" role="tabpanel" aria-labelledby="tab-java">
    {allstateJavaPatterns.map(section => (
      <Fragment>
        <div class="section-label">{section.label}</div>
        <div class="pattern-grid">
          {section.cards.map(card => <PatternCard {...card} />)}
        </div>
      </Fragment>
    ))}
  </div>

  <div id="panel-questions" class="panel" role="tabpanel" aria-labelledby="tab-questions">
    {allstateQuestions.map(q => <QuestionCard {...q} />)}
  </div>

  <div id="panel-plan" class="panel" role="tabpanel" aria-labelledby="tab-plan">
    <GamePlanPanel {...allstateGamePlan} />
  </div>

  <div id="panel-experience" class="panel" role="tabpanel" aria-labelledby="tab-experience">
    <MappingPanel {...allstateExperience} />
  </div>

  <div id="panel-design" class="panel" role="tabpanel" aria-labelledby="tab-design">
    <SystemDesignPanel topics={allstateExtras.systemDesign} />
  </div>

  <div id="panel-intro" class="panel" role="tabpanel" aria-labelledby="tab-intro">
    <IntroPanel {...allstateExtras.intro} />
  </div>

  <div id="panel-stories" class="panel" role="tabpanel" aria-labelledby="tab-stories">
    <StoryRouter routes={allstateExtras.storyRoutes} />
  </div>
</CheatsheetLayout>
