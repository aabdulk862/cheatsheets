---
import '../styles/global.css';

const techDepth = [
  { level: 'Expert', techs: ['Java 21', 'Spring Boot 3.x', 'Spring Cloud Config', 'Spring Cache', 'Kafka (22+ consumers)', 'CloudWatch', 'AWS EKS', 'ArgoCD', 'MariaDB', 'GitLab CI/CD', 'Docker'] },
  { level: 'Proficient', techs: ['Spring Batch', 'Spring Cloud Stream', 'RabbitMQ', 'MapStruct', 'Jasypt', 'Resilience4j', 'Helm', 'AWS S3', 'AWS Pinpoint', 'Lombok', 'SQL/Stored Procs'] },
  { level: 'Familiar', techs: ['Spring Security', 'Oracle', 'Angular', 'React', 'Kinesis', 'SQS', 'AWS Connect'] },
];

const accomplishments = [
  { title: 'PSA NPE Fix', metric: '16K msgs/hr saved', desc: 'Fixed Collectors.toMap() null crash dropping outage notifications. Traced across @Async boundaries. 20 tests with prod payloads.' },
  { title: 'Error Categorization', metric: '9.7M records/year', desc: 'Designed cross-service taxonomy: 42 call sites, 3 repos, 75 DB rows. BI can now build dashboards on delivery failures.' },
  { title: 'OTP Encryption Deploy', metric: '5 runbook errors caught', desc: 'Took deployment ownership. Encrypt-at-source, decrypt-at-delivery. Validated all 5 channels via CloudWatch.' },
  { title: 'CPNI Props-Only Fix', metric: '69→0 errors/day', desc: 'Zero code change — appended ORDER BY + LIMIT 1 to externalized SQL. Navigated undocumented EKS migration.' },
  { title: 'Service Extraction', metric: 'Monolith → Microservice', desc: 'Extracted Appointment Service from Tech Tracker. Stripped 4 dependency trees. Demoed to Director.' },
  { title: 'Stability Backlog', metric: '14 risks identified', desc: 'Applied Release It! to prod codebase. Found thread leaks, missing circuit breakers, chunk loss on deploys.' },
];

const storyRouter = [
  { prompt: 'Production incident', story: 'PSA NPE — 16K msgs/hr silent drop, traced @Async exception swallowing' },
  { prompt: 'Cross-team collaboration', story: 'Error Categorization — 4+ teams, BI changed schema 3x, delivered on schedule' },
  { prompt: 'Taking ownership', story: 'OTP Deployment — found 5 runbook errors, prevented customer-visible ENC(...) text' },
  { prompt: 'Navigating ambiguity', story: 'CPNI Fix — discovered undocumented Swarm→EKS migration, created guide for team' },
  { prompt: 'Technical disagreement', story: 'Null Preservation — chose harder approach because filtering = silent data loss' },
  { prompt: 'Going above and beyond', story: 'Design Pivot — scrapped approved pattern-matching plan, proposed ID-based DB lookup instead (fragile vs maintainable)' },
  { prompt: 'Handling scope changes', story: 'Error IDs changed 3x mid-sprint — remapped all, caught 10 rules BI missed' },
  { prompt: 'Compliance-sensitive work', story: 'CPNI Federal Compliance — Telecom Act 1996, 5+ repos, zero code changes needed' },
];

const interviews = [
  {
    name: 'Wells Fargo',
    href: '/wellsfargo',
    accent: '#CD1409',
    format: 'Phone → HackerRank → 2-3 Technical → Behavioral',
    stack: ['Java', 'Spring Boot', 'React', 'Angular', 'Kafka', 'Azure', 'Docker'],
    timer: 60,
    difficulty: 'Medium',
  },
  {
    name: 'Shutterfly',
    href: '/shutterfly',
    accent: '#6B2D8B',
    format: 'Phone Screen → 2 Technical (Java + Architecture) → Managerial',
    stack: ['Java', 'Spring Boot', 'Python', 'AWS', 'Aurora', 'RabbitMQ', 'ECS'],
    timer: 60,
    difficulty: 'Medium',
  },
  {
    name: 'Chmura',
    href: '/chmura',
    accent: '#1B5E20',
    format: 'Phone → Skills Test → Panel Interview',
    stack: ['Angular', 'TypeScript', 'RxJS', 'Signals', 'Material', 'Vitest'],
    timer: 60,
    difficulty: 'Easy-Medium',
  },
  {
    name: 'Bank of America',
    href: '/bofa',
    accent: '#012169',
    format: 'HireVue OA — Self-Intro + 2 Coding + Video + Fitment',
    stack: ['Java', 'Python', 'Arrays', 'DP', 'String', 'Trees'],
    timer: 90,
    difficulty: 'Medium',
  },
  {
    name: 'Allstate',
    href: '/allstate',
    accent: '#003DA5',
    format: 'Recruiter Screen → Technical Coding → Pair Programming/TDD',
    stack: ['Java', 'TDD', 'JUnit', 'Pair Programming', 'Clean Code'],
    timer: 60,
    difficulty: 'Medium',
  },
  {
    name: "Lowe's",
    href: '/lowes',
    accent: '#004990',
    format: '3 Back-to-Back Technical Panels — All Technical, No Behavioral',
    stack: ['Java 8', 'Streams', 'Kafka', 'Microservices', 'SQL', 'Docker'],
    timer: 90,
    difficulty: 'Medium-Hard',
  },
  {
    name: 'Truist',
    href: '/truist',
    accent: '#532E8A',
    format: 'Recruiter Screen → Technical Interview(s) — Banking Focus',
    stack: ['Java', 'SQL', 'Banking Domain', 'Spring Boot'],
    timer: 60,
    difficulty: 'Medium',
  },
];

const playbooks = [
  {
    name: 'Infosys',
    href: '/infosys',
    accent: '#007CC3',
    description: 'Full-stack knowledge base covering Java, Spring, SQL, React, HTTP, Cloud, Coding, and Git. No timer — use as a reference.',
    topics: ['Java', 'Spring', 'SQL', 'React', 'HTTP', 'Cloud', 'Coding', 'Git'],
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Interview Prep — Cheatsheets</title>
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="manifest" href="/site.webmanifest" />
  </head>
  <body>
    <div class="root landing">
      <!-- Hero -->
      <header class="hero">
        <div class="hero-badge">🎯 {interviews.length} Companies · {playbooks.length} Playbook</div>
        <h1>Interview Cheatsheets</h1>
        <p class="hero-sub">Tabbed, searchable, single-page references with code patterns, likely questions, and game plans.</p>
      </header>

      <!-- Interview Prep Cards -->
      <section class="section">
        <div class="section-header">
          <h2>Interview Prep</h2>
          <span class="section-badge">{interviews.length} companies</span>
        </div>

        <div class="interview-grid">
          {interviews.map((company) => (
            <a href={company.href} class="interview-card" style={`--card-accent: ${company.accent};`}>
              <div class="card-top">
                <span class="card-name">{company.name}</span>
                <span class="card-timer">{company.timer} min</span>
              </div>
              <p class="card-format">{company.format}</p>
              <div class="card-tags">
                {company.stack.slice(0, 5).map(tag => (
                  <span class="tag">{tag}</span>
                ))}
                {company.stack.length > 5 && <span class="tag tag-more">+{company.stack.length - 5}</span>}
              </div>
              <div class="card-footer">
                <span class="card-difficulty">{company.difficulty}</span>
                <span class="card-arrow">→</span>
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- Playbooks Section -->
      <section class="section">
        <div class="section-header">
          <h2>Playbooks</h2>
          <span class="section-badge">Reference guides</span>
        </div>

        {playbooks.map((book) => (
          <a href={book.href} class="playbook-card" style={`--card-accent: ${book.accent};`}>
            <div class="playbook-left">
              <span class="playbook-icon">📖</span>
            </div>
            <div class="playbook-body">
              <h3>{book.name}</h3>
              <p>{book.description}</p>
              <div class="card-tags">
                {book.topics.map(t => <span class="tag">{t}</span>)}
              </div>
            </div>
            <div class="playbook-arrow">→</div>
          </a>
        ))}
      </section>

      <!-- Master Experience Map -->
      <section class="section">
        <div class="section-header">
          <h2>Master Experience Map</h2>
          <span class="section-badge">UCC Hub · Charter/Spectrum via Infosys</span>
        </div>

        <div class="platform-context">
          <strong>Platform:</strong> 40+ Java 21/Spring Boot microservices · millions msgs/day · 31M customers · 5 channels · 22+ Kafka consumers · 114M-row tables (155GB) · AWS EKS East/West · ArgoCD GitOps
        </div>

        <h3 class="subsection-title">Technical Depth</h3>
        <div class="depth-grid">
          {techDepth.map(row => (
            <div class="depth-row">
              <span class={`depth-level depth-${row.level.toLowerCase()}`}>{row.level}</span>
              <div class="depth-techs">
                {row.techs.map(t => <span class="tag">{t}</span>)}
              </div>
            </div>
          ))}
        </div>

        <h3 class="subsection-title">Key Accomplishments</h3>
        <div class="accomplishment-grid">
          {accomplishments.map(a => (
            <div class="accomplishment-card">
              <div class="acc-top">
                <span class="acc-title">{a.title}</span>
                <span class="acc-metric">{a.metric}</span>
              </div>
              <p class="acc-desc">{a.desc}</p>
            </div>
          ))}
        </div>

        <h3 class="subsection-title">Story Router — "When They Ask → Use This"</h3>
        <div class="story-router-grid">
          {storyRouter.map(s => (
            <div class="sr-row">
              <span class="sr-prompt">"{s.prompt}"</span>
              <span class="sr-arrow">→</span>
              <span class="sr-story">{s.story}</span>
            </div>
          ))}
        </div>

        <h3 class="subsection-title">Full Stories (STAR)</h3>
        <div class="full-stories">
          <div class="full-story-card">
            <div class="fs-header">
              <span class="fs-title">Production Incident — PSA NPE (16K msgs/hr)</span>
              <span class="fs-prompt">"Tell me about a production incident" / "Tell me about a difficult bug"</span>
            </div>
            <div class="fs-body">
              <div class="fs-star"><span class="fs-label">S</span><span>About four months into my role, I got pulled into investigating a production issue on our PSA system — Proactive Service Alerts, how Spectrum notifies customers when their internet goes down. The upstream system AOM detects outages and publishes events to Kafka. Our Kafka Ingestion API consumes them, transforms them through a MapStruct mapper, and routes them for delivery. About 16,000 of these notifications per hour were silently vanishing. No alerts fired, no dead letter queue caught them. Customers with outages just never got notified.</span></div>
              <div class="fs-star"><span class="fs-label">T</span><span>I needed to figure out where messages were disappearing. The tricky part: monitoring showed zero errors — the system appeared completely healthy. I also needed to fix it, write regression tests, and deploy across both East and West production clusters.</span></div>
              <div class="fs-star"><span class="fs-label">A</span><span>I traced the execution path. Our Kafka consumers use @Async for throughput — the consumer commits the offset immediately and hands each message to a thread pool. If that thread crashes, Spring's SimpleAsyncUncaughtExceptionHandler just logs it. No retry, no DLQ, no alert. Offset already committed — message permanently gone. That's why monitoring was clean. The crash site: PsaPayloadMapper uses Collectors.toMap() which internally uses HashMap.merge() → Objects.requireNonNull() on values. AOM was sending null template parameters — instant NPE on every one. I found a second vector too: getValue().equalsIgnoreCase("Wildfire") — NPE if value is null. I challenged the initial RCA from another engineer which overcounted by conflating Lombok toString() null formatting ("value=null") with empty strings ("value=)"). Only 3 fields were actually null. For the fix, I chose HashMap.put() over filtering nulls. Filtering would make messages appear successful with missing data — no failed record, nobody would know. HashMap.put() accepts nulls, downstream validation catches them, creates proper failed records. Also applied a Yoda condition for the second vector. Wrote 20 tests with real production payloads from CloudWatch.</span></div>
              <div class="fs-star"><span class="fs-label">R</span><span>Zero messages dropped after deployment. 16K msgs/hr restored. Found a second affected template not in the original ticket. Team adopted the pattern for future MapStruct work. Deployed across QA (6 files), UAT (15 files), production East/West.</span></div>
            </div>
          </div>

          <div class="full-story-card">
            <div class="fs-header">
              <span class="fs-title">Cross-Service Error Categorization (9.7M records)</span>
              <span class="fs-prompt">"Tell me about coordinating across teams" / "Tell me about designing a system"</span>
            </div>
            <div class="fs-body">
              <div class="fs-star"><span class="fs-label">S</span><span>Our BI team — Pete Razo and Shreya Chittari — couldn't build dashboards on delivery failures. The error_description field in our main table (114 million rows, 155 GB) was freeform text. 9.7 million error records per year with zero structure. The work touched 3 microservices, 2 stored procedures owned by Gopi, an arbitration team (Jena and Smruti), QA (Praveen), and BI — all needing to ship in the same release.</span></div>
              <div class="fs-star"><span class="fs-label">T</span><span>Design a categorization system that works for both my Java code and Gopi's stored procedures, then coordinate everyone to converge on the 06.17 release.</span></div>
              <div class="fs-star"><span class="fs-label">A</span><span>Three design iterations: (1) new columns on 155GB table — rejected as too risky. (2) Publisher-only — rejected, errors originate in CPM. (3) Pipe-delimited prefix on existing field (approved). Format: "Extraction|Template Error|Template Not Enabled|original error". BI parses with split("|", 4). Old records without pipes = uncategorized. Zero schema migration. Built extract_category_mapping table (75 rows), @Cacheable service for O(1) lookups. Each call site references a hardcoded ID. For Gopi's procs: he returns "ID| error text" format, my code parses and resolves the prefix from DB. Modified 42 call sites across 3 repos. BI changed the ID scheme 3 times — from 58 to 57 to 74. Each time I maintained cross-references, regenerated SQL, caught 10 rules they missed. Coordinated Gopi (proc format), Pete/Shreya (BI categories), Jena/Smruti (arbitration), Yossi (downstream Kafka notification), Praveen (QA).</span></div>
              <div class="fs-star"><span class="fs-label">R</span><span>All 3 MRs merged. 75 DB rows categorizing 94 error patterns. BI can build dashboards on 9.7M annual failures for the first time. Extensible: new error = one INSERT + use the ID. Shipped in 06.17 release.</span></div>
            </div>
          </div>

          <div class="full-story-card">
            <div class="fs-header">
              <span class="fs-title">OTP Encryption Deployment Ownership</span>
              <span class="fs-prompt">"Tell me about taking ownership" / "Tell me about attention to detail"</span>
            </div>
            <div class="fs-body">
              <div class="fs-star"><span class="fs-label">S</span><span>OTP encryption feature was ready for UAT/production. Developer Shankar needed to hand off. The feature touches 3 services: Ingestion API encrypts OTP codes using Jasypt, PCDP decrypts before calling Pinpoint for delivery, and Email Copy Producer suppresses sensitive data in logs. Requires DB inserts, Jasypt env vars in configMaps, and 18-file ArgoCD deployment. I had zero prior involvement in building it.</span></div>
              <div class="fs-star"><span class="fs-label">T</span><span>Take full deployment ownership of a security-critical feature I didn't build. Validate in QA, deploy to UAT, prepare for production — without breaking customer-facing OTP delivery.</span></div>
              <div class="fs-star"><span class="fs-label">A</span><span>Rather than blindly following the runbook, I validated every step against the actual system. Ran CloudWatch queries to verify 5 checkpoints: encryption at Ingestion (verify_code=ENC(...)), decryption at PCDP, S3 redaction (asterisks), log suppression, non-OTP unaffected. Found 5 errors in the runbook: (1) wrong cache clear URL — /cache/all not /cache/clear (wrong one only clears one pod), (2) wrong rollback SQL — code ignores the enabled flag so the documented rollback would silently fail, (3) nonexistent DB column in INSERT, (4) wrong deployment order — PCDP must deploy before Ingestion or customers see literal "ENC(...)" text, (5) PROD West has 3 files not 5. Fixed all before execution. Managed ArgoCD sync across 5 OutOfSync UAT apps.</span></div>
              <div class="fs-star"><span class="fs-label">R</span><span>OTP deployed to UAT, all 5 checkpoints passing. 5 runbook corrections prevent future errors. Showed I can own a complex security deployment I didn't build by validating against the system rather than trusting documentation.</span></div>
            </div>
          </div>

          <div class="full-story-card">
            <div class="fs-header">
              <span class="fs-title">CPNI Props-Only Fix + Undocumented Migration</span>
              <span class="fs-prompt">"Tell me about navigating ambiguity" / "Tell me about a zero-risk fix"</span>
            </div>
            <div class="fs-body">
              <div class="fs-star"><span class="fs-label">S</span><span>Production error: queryForObject() throwing IncorrectResultSizeDataAccessException because RCS channel was recently enabled for CPNI templates. When RCS fails, SMS fallback creates a second database row. Code expected exactly 1 row — now got 2. About 400 errors/day in production logs, though no customer impact.</span></div>
              <div class="fs-star"><span class="fs-label">T</span><span>Fix with minimum risk. Also: when I went to deploy the fix to QA, nothing worked because the environment had been migrated from Docker Swarm to EKS without anyone updating documentation.</span></div>
              <div class="fs-star"><span class="fs-label">A</span><span>Chose the lowest-risk approach: our SQL is externalized in Spring Cloud Config properties, so I appended "ORDER BY jpd_id DESC LIMIT 1" to the query. The newest row (SMS fallback) always has the correct final status. Zero code change. Validated against 6 edge cases with live prod data. For the QA deployment: I discovered Portainer (Swarm) showed no services. Investigated and found everything had migrated to EKS. Had to figure out new property file naming (-eks-qa1 suffix), correct CloudWatch log groups, and that ArgoCD sync doesn't restart pods for config-only changes. Created a comprehensive EKS Deep Dive guide for the team.</span></div>
              <div class="fs-star"><span class="fs-label">R</span><span>69 errors/day → 0 instantly after pod restart. Zero code change, zero downtime. EKS guide prevents future confusion for anyone deploying to the migrated environment.</span></div>
            </div>
          </div>

          <div class="full-story-card">
            <div class="fs-header">
              <span class="fs-title">Monolith → Microservice Extraction</span>
              <span class="fs-prompt">"Tell me about decomposing a monolith" / "Tell me about a project you're proud of"</span>
            </div>
            <div class="fs-body">
              <div class="fs-star"><span class="fs-label">S</span><span>Our Tech Tracker service was a monolith combining appointment lifecycle management with Glympse real-time technician tracking, Kafka consumers for CSG work order events, S3 file handling, and Spring Batch processing. Changes to appointment logic risked breaking unrelated functionality. The service had grown organically and nobody had drawn a boundary.</span></div>
              <div class="fs-star"><span class="fs-label">T</span><span>Extract the appointment domain into a standalone microservice with reduced blast radius.</span></div>
              <div class="fs-star"><span class="fs-label">A</span><span>Mapped class dependencies to identify the bounded context. Created a new Spring Boot project with only REST APIs and RabbitMQ — the two communication patterns the appointment domain actually needs. Systematically removed 4 dependency trees that don't belong: Kafka (appointments don't consume events directly), S3 (different concern), Spring Batch (not an appointment concern), and Glympse (separate bounded context). Each removal required verifying no appointment logic accidentally depended on those libraries. Built clean API contracts for the remaining monolith to call. Presented working demo to Director of Engineering.</span></div>
              <div class="fs-star"><span class="fs-label">R</span><span>Standalone Appointment Service deployed. Changes to appointments can't break Glympse or batch processing. Director approved further decomposition along the same pattern.</span></div>
            </div>
          </div>

          <div class="full-story-card">
            <div class="fs-header">
              <span class="fs-title">Design Pivot — Pattern Matching → ID-Based Lookup</span>
              <span class="fs-prompt">"Tell me about changing your approach" / "Tell me about a design decision"</span>
            </div>
            <div class="fs-body">
              <div class="fs-star"><span class="fs-label">S</span><span>I was implementing the error categorization system for our BI team. My first approved design was a pattern-matching resolver — an ErrorCategoryResolver class with a chain of startsWith/contains checks that would match freeform error text to categories. I'd already scoped it to 19 patterns covering 838K records/year. But as I dug deeper into the codebase (reading the ~2000-line stored procedure, tracing all 30+ setErrorDescription call sites, running CloudWatch queries on production), I realized the pattern-matching approach was fundamentally fragile.</span></div>
              <div class="fs-star"><span class="fs-label">T</span><span>I needed to decide whether to continue with the approved pattern-matching plan (which was already scoped and ready to implement) or propose a fundamentally different approach that would require re-planning — but be correct long-term.</span></div>
              <div class="fs-star"><span class="fs-label">A</span><span>I identified the core problem: pattern matching breaks silently when error messages change. If someone updates a log message from "Couldn't determine" to "Unable to determine", the matcher stops working and errors go uncategorized again — with no alert. The code that generates the error already knows what went wrong, so it should declare the category at the source. I proposed an ID-based DB lookup instead: a table with serial IDs mapped to structured prefixes, and each error-generating call site references its ID directly. No pattern matching, no fragile string chains. I rewrote the plan: dropped the ErrorCategoryResolver class entirely, dropped the post-hoc hook points, created extract_category_mapping table (75 rows), and built an @Cacheable thin wrapper. Each call site becomes: setErrorDescription(getDescription(15) + dynamicText). New errors = INSERT one row + use the ID. Other teams (stored procs, arbitration) can adopt the same pattern with their own ID ranges. Submitted the revised plan and got it approved. Then during code review, the team suggested switching from my manual ConcurrentHashMap + @EventListener to Spring @Cacheable — I incorporated that feedback and simplified further.</span></div>
              <div class="fs-star"><span class="fs-label">R</span><span>The ID-based approach is now implemented across 42 call sites in 3 services. It's fundamentally more maintainable — no pattern matching that silently breaks. Extensible: new error = one INSERT. Other teams adopted the same ID pattern for their stored procs and arbitration rules. The pivot added one day of re-planning but saved months of future maintenance from fragile string matching.</span></div>
            </div>
          </div>
        </div>
      </section>
    </div>

    <style>
      /* Hero */
      .hero {
        text-align: center;
        padding: 2.5rem 1rem 2rem;
      }

      .hero-badge {
        display: inline-block;
        font-size: 12px;
        font-weight: 500;
        color: var(--color-text-secondary);
        background: var(--color-background-primary);
        border: 1px solid var(--color-border-tertiary);
        border-radius: 20px;
        padding: 4px 14px;
        margin-bottom: 12px;
      }

      .hero h1 {
        font-size: 32px;
        font-weight: 800;
        color: var(--color-text-primary);
        margin-bottom: 8px;
        letter-spacing: -0.5px;
      }

      .hero-sub {
        font-size: 15px;
        color: var(--color-text-secondary);
        max-width: 520px;
        margin: 0 auto;
        line-height: 1.5;
      }

      /* Sections */
      .section {
        margin-bottom: 2.5rem;
      }

      .section-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--color-border-tertiary);
      }

      .section-header h2 {
        font-size: 18px;
        font-weight: 700;
        color: var(--color-text-primary);
      }

      .section-badge {
        font-size: 11px;
        font-weight: 500;
        color: var(--color-text-tertiary);
        background: var(--color-background-primary);
        border: 1px solid var(--color-border-tertiary);
        border-radius: 12px;
        padding: 2px 10px;
      }

      /* Interview Grid */
      .interview-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 14px;
      }

      .interview-card {
        display: flex;
        flex-direction: column;
        gap: 10px;
        background: var(--color-background-primary);
        border: 1px solid var(--color-border-tertiary);
        border-radius: var(--border-radius-lg);
        padding: 1.25rem;
        text-decoration: none;
        color: inherit;
        border-left: 5px solid var(--card-accent);
        transition: box-shadow 0.15s, transform 0.15s;
      }

      .interview-card:hover {
        box-shadow: 0 6px 24px rgba(0, 0, 0, 0.08);
        transform: translateY(-2px);
      }

      .card-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .card-name {
        font-size: 16px;
        font-weight: 700;
        color: var(--color-text-primary);
      }

      .card-timer {
        font-size: 11px;
        font-weight: 600;
        color: var(--card-accent);
        background: color-mix(in srgb, var(--card-accent) 8%, transparent);
        border-radius: 6px;
        padding: 3px 8px;
      }

      .card-format {
        font-size: 12.5px;
        color: var(--color-text-secondary);
        line-height: 1.4;
      }

      .card-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 5px;
      }

      .tag {
        font-size: 11px;
        font-weight: 500;
        color: var(--color-text-secondary);
        background: var(--color-background-secondary);
        border-radius: 4px;
        padding: 2px 7px;
      }

      .tag-more {
        color: var(--color-text-tertiary);
        font-style: italic;
      }

      .card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: auto;
        padding-top: 6px;
      }

      .card-difficulty {
        font-size: 11px;
        font-weight: 500;
        color: var(--color-text-tertiary);
      }

      .card-arrow {
        font-size: 18px;
        font-weight: 300;
        color: var(--color-text-tertiary);
        transition: color 0.15s, transform 0.15s;
      }

      .interview-card:hover .card-arrow {
        color: var(--card-accent);
        transform: translateX(3px);
      }

      /* Playbook Card */
      .playbook-card {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        background: var(--color-background-primary);
        border: 1px solid var(--color-border-tertiary);
        border-radius: var(--border-radius-lg);
        padding: 1.5rem;
        text-decoration: none;
        color: inherit;
        transition: box-shadow 0.15s, transform 0.15s;
      }

      .playbook-card:hover {
        box-shadow: 0 6px 24px rgba(0, 0, 0, 0.08);
        transform: translateY(-2px);
      }

      .playbook-left {
        font-size: 32px;
        flex-shrink: 0;
      }

      .playbook-body {
        flex: 1;
        min-width: 0;
      }

      .playbook-body h3 {
        font-size: 16px;
        font-weight: 700;
        color: var(--color-text-primary);
        margin-bottom: 4px;
      }

      .playbook-body p {
        font-size: 13px;
        color: var(--color-text-secondary);
        margin-bottom: 10px;
        line-height: 1.4;
      }

      .playbook-arrow {
        font-size: 20px;
        color: var(--color-text-tertiary);
        flex-shrink: 0;
        transition: color 0.15s, transform 0.15s;
      }

      .playbook-card:hover .playbook-arrow {
        color: var(--card-accent);
        transform: translateX(3px);
      }

      /* Responsive */
      @media (max-width: 768px) {
        .hero h1 { font-size: 26px; }
        .interview-grid { grid-template-columns: 1fr; }
        .playbook-card { flex-direction: column; align-items: flex-start; gap: 0.75rem; }
        .playbook-arrow { display: none; }
        .sr-row { flex-direction: column; align-items: flex-start; gap: 2px; }
        .sr-arrow { display: none; }
        .depth-row { flex-direction: column; gap: 6px; }
        .accomplishment-grid { grid-template-columns: 1fr; }
        .sr-prompt { min-width: 0; font-size: 12px; }
        .sr-story { font-size: 11.5px; }
        .acc-top { flex-wrap: wrap; gap: 4px; }
        .platform-context { font-size: 12px; }
        .full-story-card { padding: 1rem; }
        .fs-title { font-size: 13px; }
        .fs-star { font-size: 12px; gap: 8px; }
      }

      @media (max-width: 480px) {
        .hero h1 { font-size: 22px; }
        .hero-sub { font-size: 13px; }
        .section-header h2 { font-size: 16px; }
        .accomplishment-card { padding: 10px 12px; }
        .acc-title { font-size: 12px; }
        .acc-desc { font-size: 11px; }
        .sr-row { padding: 8px 10px; }
        .depth-level { font-size: 10px; min-width: 70px; }
        .full-story-card { padding: 0.75rem; }
        .fs-title { font-size: 12.5px; }
        .fs-star { font-size: 11.5px; line-height: 1.5; }
      }

      @media (min-width: 1200px) {
        .interview-grid { grid-template-columns: repeat(3, 1fr); }
      }

      /* Master Experience Map */
      .platform-context {
        font-size: 13px; color: var(--color-text-secondary); line-height: 1.6;
        background: var(--color-background-primary); border: 1px solid var(--color-border-tertiary);
        border-radius: var(--border-radius-lg); padding: 12px 16px; margin-bottom: 1.5rem;
      }
      .subsection-title {
        font-size: 14px; font-weight: 700; color: var(--color-text-primary);
        margin: 1.25rem 0 0.75rem; padding-bottom: 4px;
        border-bottom: 1px solid var(--color-border-tertiary);
      }
      .depth-grid { display: flex; flex-direction: column; gap: 8px; margin-bottom: 1rem; }
      .depth-row { display: flex; align-items: center; gap: 12px; }
      .depth-level {
        font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em;
        padding: 3px 10px; border-radius: 4px; min-width: 80px; text-align: center;
      }
      .depth-expert { background: #eaf3de; color: #3b6d11; }
      .depth-proficient { background: #faeeda; color: #854f0b; }
      .depth-familiar { background: #e6f1fb; color: #0c447c; }
      .depth-techs { display: flex; flex-wrap: wrap; gap: 5px; }
      .accomplishment-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 10px; margin-bottom: 1rem; }
      .accomplishment-card {
        background: var(--color-background-primary); border: 1px solid var(--color-border-tertiary);
        border-radius: var(--border-radius-lg); padding: 14px 16px;
      }
      .acc-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 6px; }
      .acc-title { font-size: 13px; font-weight: 700; color: var(--color-text-primary); }
      .acc-metric { font-size: 11px; font-weight: 600; color: #3b6d11; background: #eaf3de; border-radius: 4px; padding: 2px 8px; }
      .acc-desc { font-size: 12px; color: var(--color-text-secondary); line-height: 1.5; }
      .story-router-grid { display: flex; flex-direction: column; gap: 6px; }
      .sr-row {
        display: flex; align-items: center; gap: 10px; padding: 10px 14px;
        background: var(--color-background-primary); border: 1px solid var(--color-border-tertiary);
        border-radius: var(--border-radius-md);
      }
      .sr-prompt { font-size: 13px; font-weight: 600; color: var(--color-text-primary); min-width: 180px; }
      .sr-arrow { color: var(--color-text-tertiary); }
      .sr-story { font-size: 12px; color: var(--color-text-secondary); }

      /* Full Stories */
      .full-stories { display: flex; flex-direction: column; gap: 16px; }
      .full-story-card {
        background: var(--color-background-primary); border: 1px solid var(--color-border-tertiary);
        border-radius: var(--border-radius-lg); padding: 1.5rem; 
      }
      .fs-header { margin-bottom: 14px; }
      .fs-title { font-size: 16px; font-weight: 700; color: var(--color-text-primary); display: block; margin-bottom: 3px; }
      .fs-prompt { font-size: 12px; color: var(--color-text-tertiary); font-style: italic; }
      .fs-body { display: flex; flex-direction: column; gap: 12px; }
      .fs-star { display: flex; gap: 12px; font-size: 14px; color: var(--color-text-secondary); line-height: 1.7; }
      .fs-label { font-weight: 800; color: #4a90d9; min-width: 18px; flex-shrink: 0; font-size: 15px; }
    </style>
  </body>
</html>
