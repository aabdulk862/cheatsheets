---
import '../styles/global.css';

const techDepth = [
  { level: 'Expert', techs: ['Java 21', 'Spring Boot 3.x', 'Spring Cloud Config', 'Spring Cache', 'Kafka (22+ consumers)', 'CloudWatch', 'AWS EKS', 'ArgoCD', 'MariaDB', 'GitLab CI/CD', 'Docker'] },
  { level: 'Proficient', techs: ['Spring Batch', 'Spring Cloud Stream', 'RabbitMQ', 'MapStruct', 'Jasypt', 'Resilience4j', 'Helm', 'AWS S3', 'AWS Pinpoint', 'Lombok', 'SQL/Stored Procs'] },
  { level: 'Familiar', techs: ['Spring Security', 'Oracle', 'Angular', 'React', 'Kinesis', 'SQS', 'AWS Connect'] },
];

const accomplishments = [
  { title: 'PSA NPE Fix', metric: '16K msgs/hr saved', desc: 'Fixed Collectors.toMap() null crash dropping outage notifications. Traced across @Async boundaries. 20 tests with prod payloads.' },
  { title: 'Error Categorization', metric: '9.7M records/year', desc: 'Designed cross-service taxonomy: 42 call sites, 3 repos, 75 DB rows. BI can now build dashboards on delivery failures.' },
  { title: 'OTP Encryption Deploy', metric: '5 runbook errors caught', desc: 'Took deployment ownership. Encrypt-at-source, decrypt-at-delivery. Validated all 5 channels via CloudWatch.' },
  { title: 'CPNI Props-Only Fix', metric: '69→0 errors/day', desc: 'Zero code change — appended ORDER BY + LIMIT 1 to externalized SQL. Navigated undocumented EKS migration.' },
  { title: 'Service Extraction', metric: 'Monolith → Microservice', desc: 'Extracted Appointment Service from Tech Tracker. Stripped 4 dependency trees. Demoed to Director.' },
  { title: 'Stability Backlog', metric: '14 risks identified', desc: 'Applied Release It! to prod codebase. Found thread leaks, missing circuit breakers, chunk loss on deploys.' },
];

const storyRouter = [
  { prompt: 'Production incident', story: 'PSA NPE — 16K msgs/hr silent drop, traced @Async exception swallowing' },
  { prompt: 'Cross-team collaboration', story: 'Error Categorization — 4+ teams, BI changed schema 3x, delivered on schedule' },
  { prompt: 'Taking ownership', story: 'OTP Deployment — found 5 runbook errors, prevented customer-visible ENC(...) text' },
  { prompt: 'Navigating ambiguity', story: 'CPNI Fix — discovered undocumented Swarm→EKS migration, created guide for team' },
  { prompt: 'Technical disagreement', story: 'Null Preservation — chose harder approach because filtering = silent data loss' },
  { prompt: 'Going above and beyond', story: 'Stability Backlog + Doc Rebuild — 14 risks, 6 service docs, 5+ team errors corrected' },
  { prompt: 'Handling scope changes', story: 'Error IDs changed 3x mid-sprint — remapped all, caught 10 rules BI missed' },
  { prompt: 'Compliance-sensitive work', story: 'CPNI Federal Compliance — Telecom Act 1996, 5+ repos, zero code changes needed' },
];

const interviews = [
  {
    name: 'Wells Fargo',
    href: '/wellsfargo',
    accent: '#CD1409',
    format: 'Phone → HackerRank → 2-3 Technical → Behavioral',
    stack: ['Java', 'Spring Boot', 'React', 'Angular', 'Kafka', 'Azure', 'Docker'],
    timer: 60,
    difficulty: 'Medium',
  },
  {
    name: 'Shutterfly',
    href: '/shutterfly',
    accent: '#6B2D8B',
    format: 'Phone Screen → 2 Technical (Java + Architecture) → Managerial',
    stack: ['Java', 'Spring Boot', 'Python', 'AWS', 'Aurora', 'RabbitMQ', 'ECS'],
    timer: 60,
    difficulty: 'Medium',
  },
  {
    name: 'Chmura',
    href: '/chmura',
    accent: '#1B5E20',
    format: 'Phone → Skills Test → Panel Interview',
    stack: ['Angular', 'TypeScript', 'RxJS', 'Signals', 'Material', 'Vitest'],
    timer: 60,
    difficulty: 'Easy-Medium',
  },
  {
    name: 'Bank of America',
    href: '/bofa',
    accent: '#012169',
    format: 'HireVue OA — Self-Intro + 2 Coding + Video + Fitment',
    stack: ['Java', 'Python', 'Arrays', 'DP', 'String', 'Trees'],
    timer: 90,
    difficulty: 'Medium',
  },
  {
    name: 'Allstate',
    href: '/allstate',
    accent: '#003DA5',
    format: 'Recruiter Screen → Technical Coding → Pair Programming/TDD',
    stack: ['Java', 'TDD', 'JUnit', 'Pair Programming', 'Clean Code'],
    timer: 60,
    difficulty: 'Medium',
  },
  {
    name: "Lowe's",
    href: '/lowes',
    accent: '#004990',
    format: '3 Back-to-Back Technical Panels — All Technical, No Behavioral',
    stack: ['Java 8', 'Streams', 'Kafka', 'Microservices', 'SQL', 'Docker'],
    timer: 90,
    difficulty: 'Medium-Hard',
  },
  {
    name: 'Truist',
    href: '/truist',
    accent: '#532E8A',
    format: 'Recruiter Screen → Technical Interview(s) — Banking Focus',
    stack: ['Java', 'SQL', 'Banking Domain', 'Spring Boot'],
    timer: 60,
    difficulty: 'Medium',
  },
];

const playbooks = [
  {
    name: 'Infosys',
    href: '/infosys',
    accent: '#007CC3',
    description: 'Full-stack knowledge base covering Java, Spring, SQL, React, HTTP, Cloud, Coding, and Git. No timer — use as a reference.',
    topics: ['Java', 'Spring', 'SQL', 'React', 'HTTP', 'Cloud', 'Coding', 'Git'],
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Interview Prep — Cheatsheets</title>
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="manifest" href="/site.webmanifest" />
  </head>
  <body>
    <div class="root landing">
      <!-- Hero -->
      <header class="hero">
        <div class="hero-badge">🎯 {interviews.length} Companies · {playbooks.length} Playbook</div>
        <h1>Interview Cheatsheets</h1>
        <p class="hero-sub">Tabbed, searchable, single-page references with code patterns, likely questions, and game plans.</p>
      </header>

      <!-- Interview Prep Cards -->
      <section class="section">
        <div class="section-header">
          <h2>Interview Prep</h2>
          <span class="section-badge">{interviews.length} companies</span>
        </div>

        <div class="interview-grid">
          {interviews.map((company) => (
            <a href={company.href} class="interview-card" style={`--card-accent: ${company.accent};`}>
              <div class="card-top">
                <span class="card-name">{company.name}</span>
                <span class="card-timer">{company.timer} min</span>
              </div>
              <p class="card-format">{company.format}</p>
              <div class="card-tags">
                {company.stack.slice(0, 5).map(tag => (
                  <span class="tag">{tag}</span>
                ))}
                {company.stack.length > 5 && <span class="tag tag-more">+{company.stack.length - 5}</span>}
              </div>
              <div class="card-footer">
                <span class="card-difficulty">{company.difficulty}</span>
                <span class="card-arrow">→</span>
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- Playbooks Section -->
      <section class="section">
        <div class="section-header">
          <h2>Playbooks</h2>
          <span class="section-badge">Reference guides</span>
        </div>

        {playbooks.map((book) => (
          <a href={book.href} class="playbook-card" style={`--card-accent: ${book.accent};`}>
            <div class="playbook-left">
              <span class="playbook-icon">📖</span>
            </div>
            <div class="playbook-body">
              <h3>{book.name}</h3>
              <p>{book.description}</p>
              <div class="card-tags">
                {book.topics.map(t => <span class="tag">{t}</span>)}
              </div>
            </div>
            <div class="playbook-arrow">→</div>
          </a>
        ))}
      </section>

      <!-- Master Experience Map -->
      <section class="section">
        <div class="section-header">
          <h2>Master Experience Map</h2>
          <span class="section-badge">UCC Hub · Charter/Spectrum via Infosys</span>
        </div>

        <div class="platform-context">
          <strong>Platform:</strong> 40+ Java 21/Spring Boot microservices · millions msgs/day · 31M customers · 5 channels · 22+ Kafka consumers · 114M-row tables (155GB) · AWS EKS East/West · ArgoCD GitOps
        </div>

        <h3 class="subsection-title">Technical Depth</h3>
        <div class="depth-grid">
          {techDepth.map(row => (
            <div class="depth-row">
              <span class={`depth-level depth-${row.level.toLowerCase()}`}>{row.level}</span>
              <div class="depth-techs">
                {row.techs.map(t => <span class="tag">{t}</span>)}
              </div>
            </div>
          ))}
        </div>

        <h3 class="subsection-title">Key Accomplishments</h3>
        <div class="accomplishment-grid">
          {accomplishments.map(a => (
            <div class="accomplishment-card">
              <div class="acc-top">
                <span class="acc-title">{a.title}</span>
                <span class="acc-metric">{a.metric}</span>
              </div>
              <p class="acc-desc">{a.desc}</p>
            </div>
          ))}
        </div>

        <h3 class="subsection-title">Story Router — "When They Ask → Use This"</h3>
        <div class="story-router-grid">
          {storyRouter.map(s => (
            <div class="sr-row">
              <span class="sr-prompt">"{s.prompt}"</span>
              <span class="sr-arrow">→</span>
              <span class="sr-story">{s.story}</span>
            </div>
          ))}
        </div>
      </section>
    </div>

    <style>
      /* Hero */
      .hero {
        text-align: center;
        padding: 2.5rem 1rem 2rem;
      }

      .hero-badge {
        display: inline-block;
        font-size: 12px;
        font-weight: 500;
        color: var(--color-text-secondary);
        background: var(--color-background-primary);
        border: 1px solid var(--color-border-tertiary);
        border-radius: 20px;
        padding: 4px 14px;
        margin-bottom: 12px;
      }

      .hero h1 {
        font-size: 32px;
        font-weight: 800;
        color: var(--color-text-primary);
        margin-bottom: 8px;
        letter-spacing: -0.5px;
      }

      .hero-sub {
        font-size: 15px;
        color: var(--color-text-secondary);
        max-width: 520px;
        margin: 0 auto;
        line-height: 1.5;
      }

      /* Sections */
      .section {
        margin-bottom: 2.5rem;
      }

      .section-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--color-border-tertiary);
      }

      .section-header h2 {
        font-size: 18px;
        font-weight: 700;
        color: var(--color-text-primary);
      }

      .section-badge {
        font-size: 11px;
        font-weight: 500;
        color: var(--color-text-tertiary);
        background: var(--color-background-primary);
        border: 1px solid var(--color-border-tertiary);
        border-radius: 12px;
        padding: 2px 10px;
      }

      /* Interview Grid */
      .interview-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 14px;
      }

      .interview-card {
        display: flex;
        flex-direction: column;
        gap: 10px;
        background: var(--color-background-primary);
        border: 1px solid var(--color-border-tertiary);
        border-radius: var(--border-radius-lg);
        padding: 1.25rem;
        text-decoration: none;
        color: inherit;
        border-left: 5px solid var(--card-accent);
        transition: box-shadow 0.15s, transform 0.15s;
      }

      .interview-card:hover {
        box-shadow: 0 6px 24px rgba(0, 0, 0, 0.08);
        transform: translateY(-2px);
      }

      .card-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .card-name {
        font-size: 16px;
        font-weight: 700;
        color: var(--color-text-primary);
      }

      .card-timer {
        font-size: 11px;
        font-weight: 600;
        color: var(--card-accent);
        background: color-mix(in srgb, var(--card-accent) 8%, transparent);
        border-radius: 6px;
        padding: 3px 8px;
      }

      .card-format {
        font-size: 12.5px;
        color: var(--color-text-secondary);
        line-height: 1.4;
      }

      .card-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 5px;
      }

      .tag {
        font-size: 11px;
        font-weight: 500;
        color: var(--color-text-secondary);
        background: var(--color-background-secondary);
        border-radius: 4px;
        padding: 2px 7px;
      }

      .tag-more {
        color: var(--color-text-tertiary);
        font-style: italic;
      }

      .card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: auto;
        padding-top: 6px;
      }

      .card-difficulty {
        font-size: 11px;
        font-weight: 500;
        color: var(--color-text-tertiary);
      }

      .card-arrow {
        font-size: 18px;
        font-weight: 300;
        color: var(--color-text-tertiary);
        transition: color 0.15s, transform 0.15s;
      }

      .interview-card:hover .card-arrow {
        color: var(--card-accent);
        transform: translateX(3px);
      }

      /* Playbook Card */
      .playbook-card {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        background: var(--color-background-primary);
        border: 1px solid var(--color-border-tertiary);
        border-radius: var(--border-radius-lg);
        padding: 1.5rem;
        text-decoration: none;
        color: inherit;
        transition: box-shadow 0.15s, transform 0.15s;
      }

      .playbook-card:hover {
        box-shadow: 0 6px 24px rgba(0, 0, 0, 0.08);
        transform: translateY(-2px);
      }

      .playbook-left {
        font-size: 32px;
        flex-shrink: 0;
      }

      .playbook-body {
        flex: 1;
        min-width: 0;
      }

      .playbook-body h3 {
        font-size: 16px;
        font-weight: 700;
        color: var(--color-text-primary);
        margin-bottom: 4px;
      }

      .playbook-body p {
        font-size: 13px;
        color: var(--color-text-secondary);
        margin-bottom: 10px;
        line-height: 1.4;
      }

      .playbook-arrow {
        font-size: 20px;
        color: var(--color-text-tertiary);
        flex-shrink: 0;
        transition: color 0.15s, transform 0.15s;
      }

      .playbook-card:hover .playbook-arrow {
        color: var(--card-accent);
        transform: translateX(3px);
      }

      /* Responsive */
      @media (max-width: 768px) {
        .hero h1 { font-size: 26px; }
        .interview-grid { grid-template-columns: 1fr; }
        .playbook-card { flex-direction: column; align-items: flex-start; gap: 0.75rem; }
        .playbook-arrow { display: none; }
        .sr-row { flex-direction: column; align-items: flex-start; gap: 2px; }
        .sr-arrow { display: none; }
        .depth-row { flex-direction: column; gap: 6px; }
      }

      @media (min-width: 1200px) {
        .interview-grid { grid-template-columns: repeat(3, 1fr); }
      }

      /* Master Experience Map */
      .platform-context {
        font-size: 13px; color: var(--color-text-secondary); line-height: 1.6;
        background: var(--color-background-primary); border: 1px solid var(--color-border-tertiary);
        border-radius: var(--border-radius-lg); padding: 12px 16px; margin-bottom: 1.5rem;
      }
      .subsection-title {
        font-size: 14px; font-weight: 700; color: var(--color-text-primary);
        margin: 1.25rem 0 0.75rem; padding-bottom: 4px;
        border-bottom: 1px solid var(--color-border-tertiary);
      }
      .depth-grid { display: flex; flex-direction: column; gap: 8px; margin-bottom: 1rem; }
      .depth-row { display: flex; align-items: center; gap: 12px; }
      .depth-level {
        font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em;
        padding: 3px 10px; border-radius: 4px; min-width: 80px; text-align: center;
      }
      .depth-expert { background: #eaf3de; color: #3b6d11; }
      .depth-proficient { background: #faeeda; color: #854f0b; }
      .depth-familiar { background: #e6f1fb; color: #0c447c; }
      .depth-techs { display: flex; flex-wrap: wrap; gap: 5px; }
      .accomplishment-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 10px; margin-bottom: 1rem; }
      .accomplishment-card {
        background: var(--color-background-primary); border: 1px solid var(--color-border-tertiary);
        border-radius: var(--border-radius-lg); padding: 14px 16px;
      }
      .acc-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 6px; }
      .acc-title { font-size: 13px; font-weight: 700; color: var(--color-text-primary); }
      .acc-metric { font-size: 11px; font-weight: 600; color: #3b6d11; background: #eaf3de; border-radius: 4px; padding: 2px 8px; }
      .acc-desc { font-size: 12px; color: var(--color-text-secondary); line-height: 1.5; }
      .story-router-grid { display: flex; flex-direction: column; gap: 6px; }
      .sr-row {
        display: flex; align-items: center; gap: 10px; padding: 10px 14px;
        background: var(--color-background-primary); border: 1px solid var(--color-border-tertiary);
        border-radius: var(--border-radius-md);
      }
      .sr-prompt { font-size: 13px; font-weight: 600; color: var(--color-text-primary); min-width: 180px; }
      .sr-arrow { color: var(--color-text-tertiary); }
      .sr-story { font-size: 12px; color: var(--color-text-secondary); }
    </style>
  </body>
</html>
