---
import CheatsheetLayout from '../layouts/CheatsheetLayout.astro';
import PatternCard from '../components/PatternCard.astro';
import QuestionCard from '../components/QuestionCard.astro';
import GamePlanPanel from '../components/GamePlanPanel.astro';
import MappingPanel from '../components/MappingPanel.astro';
import SystemDesignPanel from '../components/SystemDesignPanel.astro';
import IntroPanel from '../components/IntroPanel.astro';
import StoryRouter from '../components/StoryRouter.astro';
import { shutterflyConfig, shutterflyBackendPatterns, shutterflyCloudPatterns, shutterflyCodePatterns, shutterflyQuestions, shutterflyGamePlan } from '../data/shutterfly';
import { shutterflyExperience } from '../data/experience-shutterfly';
import { shutterflyExtras } from '../data/interview-extras';
---

<CheatsheetLayout
  title={shutterflyConfig.title}
  subtitle={shutterflyConfig.subtitle}
  accentColor={shutterflyConfig.accentColor}
  accentSecondary={shutterflyConfig.accentSecondary}
  tabs={shutterflyConfig.tabs}
  timerMinutes={shutterflyConfig.timerMinutes}
  hasSearch={true}
>
  <div id="panel-backend" class="panel active" role="tabpanel" aria-labelledby="tab-backend">
    {shutterflyBackendPatterns.map(section => (
      <Fragment>
        <div class="section-label">{section.label}</div>
        <div class="pattern-grid">
          {section.cards.map(card => <PatternCard {...card} />)}
        </div>
      </Fragment>
    ))}
  </div>

  <div id="panel-cloud" class="panel" role="tabpanel" aria-labelledby="tab-cloud">
    {shutterflyCloudPatterns.map(section => (
      <Fragment>
        <div class="section-label">{section.label}</div>
        <div class="pattern-grid">
          {section.cards.map(card => <PatternCard {...card} />)}
        </div>
      </Fragment>
    ))}
  </div>

  <div id="panel-coding" class="panel" role="tabpanel" aria-labelledby="tab-coding">
    {shutterflyCodePatterns.map(section => (
      <Fragment>
        <div class="section-label">{section.label}</div>
        <div class="pattern-grid">
          {section.cards.map(card => <PatternCard {...card} />)}
        </div>
      </Fragment>
    ))}
  </div>

  <div id="panel-questions" class="panel" role="tabpanel" aria-labelledby="tab-questions">
    {shutterflyQuestions.map(q => <QuestionCard {...q} />)}
  </div>

  <div id="panel-plan" class="panel" role="tabpanel" aria-labelledby="tab-plan">
    <GamePlanPanel {...shutterflyGamePlan} />
  </div>

  <div id="panel-experience" class="panel" role="tabpanel" aria-labelledby="tab-experience">
    <MappingPanel {...shutterflyExperience} />
  </div>

  <div id="panel-design" class="panel" role="tabpanel" aria-labelledby="tab-design">
    <SystemDesignPanel topics={shutterflyExtras.systemDesign} />
  </div>

  <div id="panel-intro" class="panel" role="tabpanel" aria-labelledby="tab-intro">
    <IntroPanel {...shutterflyExtras.intro} />
  </div>

  <div id="panel-stories" class="panel" role="tabpanel" aria-labelledby="tab-stories">
    <StoryRouter routes={shutterflyExtras.storyRoutes} />
  </div>
</CheatsheetLayout>
