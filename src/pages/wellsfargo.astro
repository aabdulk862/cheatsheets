---
import CheatsheetLayout from '../layouts/CheatsheetLayout.astro';
import PatternCard from '../components/PatternCard.astro';
import QuestionCard from '../components/QuestionCard.astro';
import GamePlanPanel from '../components/GamePlanPanel.astro';
import MappingPanel from '../components/MappingPanel.astro';
import SystemDesignPanel from '../components/SystemDesignPanel.astro';
import IntroPanel from '../components/IntroPanel.astro';
import StoryRouter from '../components/StoryRouter.astro';
import { wellsFargoConfig, wellsFargoJavaPatterns, wellsFargoFrontendPatterns, wellsFargoInfraPatterns, wellsFargoQuestions, wellsFargoGamePlan } from '../data/wellsfargo';
import { wellsFargoExperience } from '../data/experience-wellsfargo';
import { wellsFargoExtras } from '../data/interview-extras';
---

<CheatsheetLayout
  title={wellsFargoConfig.title}
  subtitle={wellsFargoConfig.subtitle}
  accentColor={wellsFargoConfig.accentColor}
  accentSecondary={wellsFargoConfig.accentSecondary}
  tabs={wellsFargoConfig.tabs}
  timerMinutes={wellsFargoConfig.timerMinutes}
  hasSearch={true}
>
  <div id="panel-java" class="panel active" role="tabpanel" aria-labelledby="tab-java">
    {wellsFargoJavaPatterns.map(section => (
      <Fragment>
        <div class="section-label">{section.label}</div>
        <div class="pattern-grid">
          {section.cards.map(card => <PatternCard {...card} />)}
        </div>
      </Fragment>
    ))}
  </div>

  <div id="panel-frontend" class="panel" role="tabpanel" aria-labelledby="tab-frontend">
    {wellsFargoFrontendPatterns.map(section => (
      <Fragment>
        <div class="section-label">{section.label}</div>
        <div class="pattern-grid">
          {section.cards.map(card => <PatternCard {...card} />)}
        </div>
      </Fragment>
    ))}
  </div>

  <div id="panel-infra" class="panel" role="tabpanel" aria-labelledby="tab-infra">
    {wellsFargoInfraPatterns.map(section => (
      <Fragment>
        <div class="section-label">{section.label}</div>
        <div class="pattern-grid">
          {section.cards.map(card => <PatternCard {...card} />)}
        </div>
      </Fragment>
    ))}
  </div>

  <div id="panel-questions" class="panel" role="tabpanel" aria-labelledby="tab-questions">
    {wellsFargoQuestions.map(q => <QuestionCard {...q} />)}
  </div>

  <div id="panel-plan" class="panel" role="tabpanel" aria-labelledby="tab-plan">
    <GamePlanPanel {...wellsFargoGamePlan} />
  </div>

  <div id="panel-experience" class="panel" role="tabpanel" aria-labelledby="tab-experience">
    <MappingPanel {...wellsFargoExperience} />
  </div>

  <div id="panel-design" class="panel" role="tabpanel" aria-labelledby="tab-design">
    <SystemDesignPanel topics={wellsFargoExtras.systemDesign} />
  </div>

  <div id="panel-intro" class="panel" role="tabpanel" aria-labelledby="tab-intro">
    <IntroPanel {...wellsFargoExtras.intro} />
  </div>

  <div id="panel-stories" class="panel" role="tabpanel" aria-labelledby="tab-stories">
    <StoryRouter routes={wellsFargoExtras.storyRoutes} />
  </div>
</CheatsheetLayout>
