---
import type { ExperiencePanelConfig } from '../data/types';

interface Props extends ExperiencePanelConfig {}

const { mappings, stories, gaps } = Astro.props;

const levelColor = (l: string) => l === 'expert' ? 'badge-easy' : l === 'proficient' ? 'badge-medium' : 'badge-hard';
const gapColor = (s: string) => s === 'strong' ? 'badge-easy' : s === 'partial' ? 'badge-medium' : 'badge-hard';
---

<div class="mapping-panel">
  <div class="section-label">Experience Mappings</div>
  <div class="mapping-grid">
    {mappings.map(m => (
      <div class="mapping-card">
        <div class="mapping-header">
          <span class="mapping-topic">{m.topic}</span>
          <span class={`badge ${levelColor(m.level)}`}>{m.level}</span>
        </div>
        <ul class="mapping-evidence">
          {m.evidence.map(e => <li>{e}</li>)}
        </ul>
        <div class="mapping-tp">
          <strong>Interview Script</strong>
          "{m.talkingPoint}"
        </div>
      </div>
    ))}
  </div>

  <div class="section-label">Behavioral Stories (STAR)</div>
  <div class="stories-grid">
    {stories.map(s => (
      <div class="story-card">
        <div class="story-header">
          <span class="story-title">{s.title}</span>
          <span class="story-prompt">"{s.prompt}"</span>
        </div>
        <div class="star-grid">
          <div class="star-item"><span class="star-label">S</span><span>{s.situation}</span></div>
          <div class="star-item"><span class="star-label">T</span><span>{s.task}</span></div>
          <div class="star-item"><span class="star-label">A</span><span>{s.action}</span></div>
          <div class="star-item"><span class="star-label">R</span><span>{s.result}</span></div>
        </div>
      </div>
    ))}
  </div>

  <div class="section-label">Gap Analysis</div>
  <div class="gap-grid">
    {gaps.map(g => (
      <div class="gap-item">
        <span class={`badge ${gapColor(g.status)}`}>{g.status}</span>
        <span class="gap-topic">{g.topic}</span>
        {g.note && <span class="gap-note">{g.note}</span>}
      </div>
    ))}
  </div>
</div>

<style>
  .mapping-grid {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .mapping-card {
    background: var(--color-background-primary);
    border: 1px solid var(--color-border-tertiary);
    border-radius: var(--border-radius-lg);
    padding: 1.25rem 1.5rem;
    border-left: 4px solid var(--color-accent);
  }
  .mapping-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--color-border-tertiary);
  }
  .mapping-topic {
    font-size: 16px;
    font-weight: 700;
    color: var(--color-text-primary);
  }
  .mapping-evidence {
    padding-left: 1.25rem;
    font-size: 13.5px;
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: 14px;
  }
  .mapping-evidence li {
    margin-bottom: 4px;
  }
  .mapping-tp {
    font-size: 14px;
    color: var(--color-text-primary);
    background: var(--color-background-secondary);
    border-radius: var(--border-radius-md);
    padding: 14px 18px;
    line-height: 1.75;
    border-left: 4px solid var(--color-accent);
  }
  .mapping-tp strong {
    color: var(--color-accent);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: block;
    margin-bottom: 4px;
  }
  .stories-grid {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .story-card {
    background: var(--color-background-primary);
    border: 1px solid var(--color-border-tertiary);
    border-radius: var(--border-radius-lg);
    padding: 1.25rem 1.5rem;
    border-left: 4px solid var(--color-accent);
  }
  .story-header {
    margin-bottom: 14px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--color-border-tertiary);
  }
  .story-title {
    font-size: 16px;
    font-weight: 700;
    color: var(--color-text-primary);
    display: block;
    margin-bottom: 3px;
  }
  .story-prompt {
    font-size: 13px;
    color: var(--color-text-tertiary);
    font-style: italic;
  }
  .star-grid {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .star-item {
    display: flex;
    gap: 12px;
    font-size: 14px;
    color: var(--color-text-secondary);
    line-height: 1.75;
  }
  .star-label {
    font-weight: 800;
    color: var(--color-accent);
    min-width: 18px;
    font-size: 15px;
    flex-shrink: 0;
  }
  .gap-grid {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .gap-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    padding: 6px 0;
  }
  .gap-topic {
    color: var(--color-text-primary);
    font-weight: 500;
  }
  .gap-note {
    color: var(--color-text-tertiary);
    font-size: 11px;
  }
  @media (max-width: 768px) {
    .mapping-card { padding: 0.75rem 1rem; }
    .mapping-topic { font-size: 13px; }
    .mapping-evidence { font-size: 11.5px; padding-left: 1rem; }
    .mapping-tp { font-size: 11px; padding: 6px 10px; }
    .story-card { padding: 0.75rem 1rem; }
    .star-item { font-size: 11.5px; }
    .gap-item { font-size: 12px; flex-wrap: wrap; }
    .gap-note { display: block; width: 100%; margin-top: 2px; }
  }
  @media (max-width: 480px) {
    .mapping-card { padding: 0.6rem 0.75rem; }
    .mapping-header { flex-wrap: wrap; gap: 4px; }
    .mapping-evidence { font-size: 11px; line-height: 1.6; }
    .mapping-tp { font-size: 10.5px; }
    .story-title { font-size: 13px; }
    .star-item { font-size: 11px; }
  }
</style>
