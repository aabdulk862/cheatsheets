---
import type { StoryRoute } from '../data/types';

interface Props { routes: StoryRoute[] }
const { routes } = Astro.props;
---

<div class="router-panel">
  <div class="section-label">When They Ask → Use This Story</div>
  <div class="router-grid">
    {routes.map(r => (
      <div class="route-card">
        <div class="route-prompt">"{r.prompt}"</div>
        <div class="route-arrow">→</div>
        <div class="route-story">
          <span class="route-title">{r.storyTitle}</span>
          <span class="route-liner">{r.oneLiner}</span>
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  .router-grid { display: flex; flex-direction: column; gap: 8px; }
  .route-card {
    display: flex; align-items: center; gap: 14px;
    background: var(--color-background-primary);
    border: 1px solid var(--color-border-tertiary);
    border-radius: var(--border-radius-lg);
    padding: 14px 18px;
  }
  .route-prompt {
    font-size: 14px; font-weight: 600; color: var(--color-text-primary);
    min-width: 220px; flex-shrink: 0;
  }
  .route-arrow { font-size: 16px; color: var(--color-accent); flex-shrink: 0; }
  .route-story { flex: 1; min-width: 0; }
  .route-title { font-size: 14px; font-weight: 600; color: var(--color-accent); display: block; }
  .route-liner { font-size: 13px; color: var(--color-text-secondary); line-height: 1.5; }
  @media (max-width: 768px) {
    .route-card { flex-direction: column; align-items: flex-start; gap: 4px; padding: 10px 12px; }
    .route-prompt { min-width: 0; font-size: 12px; }
    .route-arrow { display: none; }
    .route-title { font-size: 12px; }
    .route-liner { font-size: 11px; }
  }
  @media (max-width: 480px) {
    .route-card { padding: 8px 10px; }
    .route-prompt { font-size: 11.5px; }
    .route-liner { font-size: 10.5px; }
  }
</style>
